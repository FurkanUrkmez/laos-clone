// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum LoyaltyPointType {
  EARN
  REDEEM
}

enum BalanceTransactionType {
  TOPUP
  PAYMENT
  REFUND
}

model Business {
  id                String   @id @default(uuid())
  name              String
  category          String
  address           String
  phone             String
  email             String
  logoUrl           String?
  workingHours      Json
  loyaltyTargetCups Int      @default(6)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branches   Branch[]
  users      User[]
  categories Category[]
  products   Product[]
  campaigns  Campaign[]

  loyaltyPointTransactions LoyaltyPointTransaction[]

  @@map("businesses")
}

model Branch {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  address      String
  phone        String
  latitude     Float?
  longitude    Float?
  workingHours Json
  createdAt    DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("branches")
}

model User {
  id            String   @id @default(uuid())
  businessId    String
  fullName      String
  email         String   @unique
  passwordHash  String
  phone         String
  phoneVerified Boolean  @default(false)
  gender        Gender   @default(UNSPECIFIED)
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  balance                  UserBalance?
  balanceTransactions      BalanceTransaction[]
  loyaltyPointTransactions LoyaltyPointTransaction[]

  @@index([businessId])
  @@map("users")
}

model Category {
  id         String @id @default(uuid())
  businessId String
  name       String
  sortOrder  Int    @default(0)

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([businessId])
  @@map("categories")
}

model Product {
  id            String  @id @default(uuid())
  categoryId    String
  businessId    String
  name          String
  description   String?
  imageUrl      String?
  pointsReward  Int     @default(1)
  price         Decimal @db.Decimal(10, 2)
  isActive      Boolean @default(true)

  category                 Category                   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  business                 Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  loyaltyPointTransactions LoyaltyPointTransaction[]

  @@index([businessId])
  @@index([categoryId])
  @@map("products")
}

model LoyaltyPointTransaction {
  id         String           @id @default(uuid())
  userId     String
  businessId String
  productId  String?
  points     Int
  type       LoyaltyPointType
  note       String?
  createdAt  DateTime         @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([businessId])
  @@map("loyalty_point_transactions")
}

model UserBalance {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balances")
}

model BalanceTransaction {
  id        String                  @id @default(uuid())
  userId    String
  amount    Decimal                 @db.Decimal(10, 2)
  type      BalanceTransactionType
  note      String?
  createdAt DateTime                @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("balance_transactions")
}

model Campaign {
  id          String   @id @default(uuid())
  businessId  String
  title       String
  description String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("campaigns")
}
